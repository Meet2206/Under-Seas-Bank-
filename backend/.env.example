# Database
# Local example:
# DATABASE_URL=postgresql://username:password@localhost:5432/banking_db
# Render supplies DATABASE_URL automatically when using render.yaml.
DATABASE_URL=postgresql://username:password@localhost:5432/banking_db

# JWT Authentication
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis and Celery
# Optional for local demo use because OTP falls back to in-memory storage.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OTP
OTP_EXPIRE_SECONDS=300

# Email delivery using SMTP
# For Gmail:
# 1. Enable 2-Step Verification.
# 2. Create a Google App Password.
# 3. Put your Gmail address in SMTP_USER and EMAIL_FROM.
# 4. Put the 16-character app password in SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-google-app-password
EMAIL_FROM=you@gmail.com

# Field-level encryption
# Required in production. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=replace-with-generated-fernet-key

# App settings
DEBUG=false
APP_NAME=Under Seas Bank API
APP_VERSION=1.0.0

# Add your hosted frontend URL here after deploy.
# Example:
# CORS_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
